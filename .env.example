# Single source of truth for local runs and Docker Compose.
#
# Copy this file to .env and update values for your environment.

DISCORD_BOT_TOKEN=replace-with-your-discord-bot-token
DISCORD_GUILD_ID=replace-with-your-discord-guild-id
DISCORD_CRITICAL_MENTION=<@your-discord-user-id>
HUB_HTTP_ADDR=127.0.0.1:8080
HUB_NOTIFY_AUTH_TOKEN=replace-with-long-random-token
HUB_NOTIFY_URL=http://127.0.0.1:8080/notify
DISCORD_CHANNEL_MAP=kalshi-alerts:replace-with-kalshi-alert-channel-id,mandarin-streaks:replace-with-mandarin-streak-channel-id
SPOKE_COMMANDS_ENABLED=true
SPOKE_COMMAND_SERVICES=[{"name":"beeminder-spoke","commandsUrl":"http://127.0.0.1:8090/control/commands","executeUrl":"http://127.0.0.1:8090/control/command"},{"name":"finance-spoke","commandsUrl":"http://127.0.0.1:8091/control/commands","executeUrl":"http://127.0.0.1:8091/control/command"},{"name":"kalshi-spoke","commandsUrl":"http://127.0.0.1:8092/control/commands","executeUrl":"http://127.0.0.1:8092/control/command"}]

# Beeminder spoke
BEEMINDER_SPOKE_HTTP_ADDR=127.0.0.1:8090
BEEMINDER_API_BASE_URL=https://www.beeminder.com/api/v1
BEEMINDER_AUTH_TOKEN=replace-with-your-beeminder-auth-token
BEEMINDER_USERNAME=replace-with-your-beeminder-username
BEEMINDER_GOAL_SLUGS=skritter
BEEMINDER_NOTIFY_CHANNEL=mandarin-streaks
BEEMINDER_NOTIFY_SEVERITY=critical

# Reminder behavior
BEEMINDER_REMINDER_START=19:00
BEEMINDER_REMINDER_INTERVAL=5m
BEEMINDER_POLL_INTERVAL=1m
BEEMINDER_ACTIVE_GRACE=20m
BEEMINDER_STARTED_SNOOZE=30m
BEEMINDER_DEFAULT_SNOOZE=30m
BEEMINDER_MAX_SNOOZE=2h
BEEMINDER_REQUIRE_DAILY_RATE=true
BEEMINDER_HTTP_TIMEOUT=10s
BEEMINDER_DATAPOINTS_PER_PAGE=100
BEEMINDER_MAX_DATAPOINT_PAGES=20

# Optional command names (beeminder-spoke owns these)
# BEEMINDER_COMMAND_STARTED=started
# BEEMINDER_COMMAND_SNOOZE=b-snooze
# BEEMINDER_COMMAND_RESUME=resume
# BEEMINDER_COMMAND_STATUS=status

# Optional extra channel mappings:
# DISCORD_CHANNEL_MAP=beeminder-streaks:1234567890,finance-summary:0987654321

# Finance spoke (weekly subscription summaries)
FINANCE_SUMMARY_ENABLED=false
FINANCE_SPOKE_HTTP_ADDR=127.0.0.1:8091
FINANCE_NOTIFY_CHANNEL=finance-summary
FINANCE_NOTIFY_SEVERITY=info
FINANCE_SUMMARY_TITLE=Weekly Subscription Summary
FINANCE_SUMMARY_WEEKDAY=SUN
FINANCE_SUMMARY_TIME=18:00
FINANCE_SUMMARY_TIMEZONE=America/New_York
FINANCE_SUMMARY_LOOKBACK_DAYS=7
FINANCE_SUMMARY_SEND_EMPTY=false
FINANCE_SUMMARY_MAX_ITEMS=20
FINANCE_SUMMARY_POLL_INTERVAL=1m
FINANCE_HTTP_TIMEOUT=15s
FINANCE_STATE_FILE=var/finance-spoke/state.json

# Accountability spoke
ACCOUNTABILITY_SPOKE_HTTP_ADDR=127.0.0.1:8093
ACCOUNTABILITY_DB_PATH=file:accountability.db?_pragma=busy_timeout(5000)
ACCOUNTABILITY_EXPIRY_POLL_INTERVAL=45s
ACCOUNTABILITY_EXPIRY_GRACE_PERIOD=12h
ACCOUNTABILITY_NOTIFY_CHANNEL=accountability
ACCOUNTABILITY_NOTIFY_SEVERITY=warning
ACCOUNTABILITY_POLICY_FILE=cmd/accountability-spoke/policies.json
ACCOUNTABILITY_OPENAI_BASE_URL=https://api.openai.com/v1
ACCOUNTABILITY_OPENAI_API_KEY=
ACCOUNTABILITY_OPENAI_MODEL=gpt-4.1-mini
ACCOUNTABILITY_OPENAI_TIMEOUT=20s
ACCOUNTABILITY_REMINDER_INTERVAL=5m
ACCOUNTABILITY_DEFAULT_SNOOZE=10m
ACCOUNTABILITY_MAX_SNOOZE=60m
ACCOUNTABILITY_COMMAND_COMMIT=commit
ACCOUNTABILITY_COMMAND_PROOF=proof
ACCOUNTABILITY_COMMAND_STATUS=accountability-status
ACCOUNTABILITY_COMMAND_CANCEL=cancel
ACCOUNTABILITY_COMMAND_SNOOZE=a-snooze

# Plaid (currently required at startup even when FINANCE_SUMMARY_ENABLED=false)
PLAID_CLIENT_ID=replace-with-your-plaid-client-id
PLAID_SECRET=replace-with-your-plaid-secret
PLAID_ENV=production
PLAID_CLIENT_NAME=Aspect Orbital Finance
PLAID_COUNTRY_CODES=US
PLAID_LANGUAGE=en
# Required by current finance-spoke startup validation
PLAID_WEBHOOK_URL=https://your-domain.example/plaid/webhook
# Comma-separated access tokens, one per linked Item (e.g. Fifth Third + Amex)
PLAID_ACCESS_TOKENS=

# Kalshi spoke (price trigger + optional auto-sell)
KALSHI_SPOKE_ENABLED=false
KALSHI_SPOKE_HTTP_ADDR=127.0.0.1:8092
KALSHI_NOTIFY_CHANNEL=kalshi-alerts
KALSHI_NOTIFY_SEVERITY=info
KALSHI_STATE_FILE=var/kalshi-spoke/state.json
KALSHI_API_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_WS_URL=wss://api.elections.kalshi.com/trade-api/ws/v2
KALSHI_ACCESS_KEY=
KALSHI_PRIVATE_KEY_PATH=
KALSHI_MARKET_TICKERS=
KALSHI_TRIGGER_RULES=
KALSHI_AUTO_SELL_ENABLED=false
KALSHI_DRY_RUN=true
KALSHI_SUBACCOUNT=0
KALSHI_HTTP_TIMEOUT=15s
KALSHI_WS_RECONNECT_DELAY=3s

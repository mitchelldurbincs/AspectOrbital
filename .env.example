DISCORD_BOT_TOKEN=replace-with-your-discord-bot-token
DISCORD_GUILD_ID=replace-with-your-discord-guild-id
DISCORD_CHANNEL_KALSHI_ALERTS=replace-with-kalshi-alert-channel-id
DISCORD_CHANNEL_MANDARIN_STREAKS=replace-with-mandarin-streak-channel-id
DISCORD_CRITICAL_MENTION=<@your-discord-user-id>
HUB_HTTP_ADDR=127.0.0.1:8080
SPOKE_COMMANDS_ENABLED=true
SPOKE_COMMANDS_URL=http://127.0.0.1:8090/control/commands
SPOKE_COMMAND_URL=http://127.0.0.1:8090/control/command

# Beeminder spoke
BEEMINDER_AUTH_TOKEN=replace-with-your-beeminder-auth-token
BEEMINDER_USERNAME=replace-with-your-beeminder-username
BEEMINDER_GOAL_SLUG=skritter
BEEMINDER_NOTIFY_CHANNEL=mandarin-streaks
DISCORD_HUB_NOTIFY_URL=http://127.0.0.1:8080/notify

# Reminder behavior
BEEMINDER_REMINDER_START=19:00
BEEMINDER_REMINDER_INTERVAL=5m
BEEMINDER_POLL_INTERVAL=1m
BEEMINDER_ACTIVE_GRACE=20m
BEEMINDER_STARTED_SNOOZE=30m
BEEMINDER_DEFAULT_SNOOZE=30m

# Optional command names (beeminder-spoke owns these)
# BEEMINDER_COMMAND_STARTED=started
# BEEMINDER_COMMAND_SNOOZE=snooze
# BEEMINDER_COMMAND_RESUME=resume
# BEEMINDER_COMMAND_STATUS=status

# Optional extra channel mappings:
# DISCORD_CHANNEL_MAP=beeminder-streaks:1234567890,ops-alerts:0987654321

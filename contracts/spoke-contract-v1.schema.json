{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aspectorbital.local/contracts/spoke-contract-v1.schema.json",
  "title": "AspectOrbital Spoke Contract V1",
  "type": "object",
  "$defs": {
    "slashName": {
      "type": "string",
      "pattern": "^[a-z0-9_-]{1,32}$"
    },
    "optionType": {
      "type": "string",
      "enum": ["string", "integer", "number", "boolean", "attachment"]
    },
    "commandOption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "description", "required"],
      "properties": {
        "name": { "$ref": "#/$defs/slashName" },
        "type": { "$ref": "#/$defs/optionType" },
        "description": { "type": "string", "minLength": 1, "maxLength": 100 },
        "required": { "type": "boolean" }
      }
    },
    "commandSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description"],
      "properties": {
        "name": { "$ref": "#/$defs/slashName" },
        "description": { "type": "string", "minLength": 1, "maxLength": 100 },
        "options": {
          "type": "array",
          "items": { "$ref": "#/$defs/commandOption" }
        }
      }
    },
    "commandCatalog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "service", "commands"],
      "properties": {
        "version": { "type": "integer", "const": 1 },
        "service": { "type": "string", "minLength": 1 },
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/commandSpec" }
        },
        "commandNames": {
          "type": "array",
          "items": { "$ref": "#/$defs/slashName" }
        }
      }
    },
    "commandContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["discordUserId"],
      "properties": {
        "discordUserId": { "type": "string", "minLength": 1 },
        "guildId": { "type": "string" },
        "channelId": { "type": "string" }
      }
    },
    "commandExecuteRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "context"],
      "properties": {
        "command": { "$ref": "#/$defs/slashName" },
        "context": { "$ref": "#/$defs/commandContext" },
        "options": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/slashName" },
          "additionalProperties": true
        }
      }
    },
    "commandExecuteResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "command", "message"],
      "properties": {
        "status": { "type": "string", "minLength": 1 },
        "command": { "$ref": "#/$defs/slashName" },
        "message": { "type": "string", "minLength": 1, "maxLength": 1900 },
        "data": {}
      }
    },
    "notifyRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["targetChannel", "message", "severity"],
      "properties": {
        "targetChannel": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "severity": { "type": "string", "enum": ["info", "warning", "critical"] }
      }
    }
  }
}

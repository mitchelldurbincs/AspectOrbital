BEEMINDER_SPOKE_HTTP_ADDR=127.0.0.1:8090
BEEMINDER_API_BASE_URL=https://www.beeminder.com/api/v1
BEEMINDER_AUTH_TOKEN=replace-with-your-beeminder-auth-token
BEEMINDER_USERNAME=replace-with-your-beeminder-username
BEEMINDER_GOAL_SLUGS=skritter
DISCORD_HUB_NOTIFY_URL=http://127.0.0.1:8080/notify
DISCORD_HUB_NOTIFY_AUTH_TOKEN=replace-with-long-random-token
BEEMINDER_NOTIFY_CHANNEL=mandarin-streaks
BEEMINDER_NOTIFY_SEVERITY=critical

# Reminder behavior
BEEMINDER_REMINDER_START=19:00
BEEMINDER_REMINDER_INTERVAL=5m
# Optional escalation schedule (HH:MM=interval, comma-separated)
# BEEMINDER_REMINDER_SCHEDULE=16:00=1h,18:00=30m,19:15=5m
# Optional quiet cutoff in local Beeminder timezone
# BEEMINDER_BEDTIME=20:00
BEEMINDER_POLL_INTERVAL=1m
BEEMINDER_ACTIVE_GRACE=20m
BEEMINDER_STARTED_SNOOZE=30m
BEEMINDER_DEFAULT_SNOOZE=30m
BEEMINDER_MAX_SNOOZE=2h
BEEMINDER_REQUIRE_DAILY_RATE=true

# Optional per-goal action URLs to include in notifications
# BEEMINDER_ACTION_URLS=skritter=https://skritter.com

# Optional tuning
BEEMINDER_HTTP_TIMEOUT=10s
BEEMINDER_DATAPOINTS_PER_PAGE=100
BEEMINDER_MAX_DATAPOINT_PAGES=20

# Optional command names
# BEEMINDER_COMMAND_STARTED=started
# BEEMINDER_COMMAND_SNOOZE=b-snooze
# BEEMINDER_COMMAND_RESUME=resume
# BEEMINDER_COMMAND_STATUS=status

# HTTP bind address for the local control API.
# Default: 127.0.0.1:8093
ACCOUNTABILITY_SPOKE_HTTP_ADDR=127.0.0.1:8093

# SQLite DSN/path for accountability data.
# Default: file:accountability.db?_pragma=busy_timeout(5000)
ACCOUNTABILITY_DB_PATH=file:accountability.db?_pragma=busy_timeout(5000)

# How often overdue commitments are checked.
# Default: 45s
ACCOUNTABILITY_EXPIRY_POLL_INTERVAL=45s

# Optional command names exposed via /control/commands.
# Defaults: commit, proof, status, cancel
# ACCOUNTABILITY_COMMAND_COMMIT=commit
# ACCOUNTABILITY_COMMAND_PROOF=proof
# ACCOUNTABILITY_COMMAND_STATUS=status
# ACCOUNTABILITY_COMMAND_CANCEL=cancel

# Optional Beeminder integration (required only when using Beeminder-backed goals).
# Default base URL: https://www.beeminder.com/api/v1
BEEMINDER_API_BASE_URL=https://www.beeminder.com/api/v1
BEEMINDER_AUTH_TOKEN=
BEEMINDER_USERNAME=

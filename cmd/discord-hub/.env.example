DISCORD_BOT_TOKEN=replace-with-your-discord-bot-token
DISCORD_GUILD_ID=replace-with-your-discord-guild-id
DISCORD_CRITICAL_MENTION=<@your-discord-user-id>
HUB_HTTP_ADDR=127.0.0.1:8080
HUB_NOTIFY_AUTH_TOKEN=replace-with-long-random-token
DISCORD_CHANNEL_MAP=kalshi-alerts:replace-with-kalshi-alert-channel-id,mandarin-streaks:replace-with-mandarin-streak-channel-id
SPOKE_COMMANDS_ENABLED=true
SPOKE_COMMAND_SERVICES=[{"name":"beeminder-spoke","commandsUrl":"http://127.0.0.1:8090/control/commands","executeUrl":"http://127.0.0.1:8090/control/command"},{"name":"finance-spoke","commandsUrl":"http://127.0.0.1:8091/control/commands","executeUrl":"http://127.0.0.1:8091/control/command"},{"name":"kalshi-spoke","commandsUrl":"http://127.0.0.1:8092/control/commands","executeUrl":"http://127.0.0.1:8092/control/command"},{"name":"accountability-spoke","commandsUrl":"http://127.0.0.1:8093/control/commands","executeUrl":"http://127.0.0.1:8093/control/command"}]

# Optional extra channel mappings:
# DISCORD_CHANNEL_MAP=kalshi-alerts:1234567890,mandarin-streaks:2345678901,finance-summary:3456789012
